      "source": [
        "# Program Pengelolaan Nilai Mahasiswa Menggunakan Array\n",
        "\n",
        "nilai = []\n",
        "\n",
        "print(\"=== INPUT NILAI MAHASISWA ===\")\n",
        "\n",
        "# Input 10 nilai\n",
        "for i in range(10):\n",
        "    n = int(input(f\"Masukkan nilai mahasiswa ke-{i+1}: \"))\n",
        "    nilai.append(n)\n",
        "\n",
        "# Nilai tertinggi dan terendah\n",
        "nilai_tertinggi = max(nilai)\n",
        "nilai_terendah = min(nilai)\n",
        "\n",
        "# Rata-rata\n",
        "rata_rata = sum(nilai) / len(nilai)\n",
        "\n",
        "# Jumlah mahasiswa lulus\n",
        "lulus = 0\n",
        "for n in nilai:\n",
        "    if n >= 60:\n",
        "        lulus += 1\n",
        "\n",
        "tidak_lulus = len(nilai) - lulus\n",
        "\n",
        "# Output\n",
        "print(\"\\n=== HASIL ANALISIS NILAI ===\")\n",
        "print(\"Daftar Nilai :\", nilai)\n",
        "print(\"Nilai Tertinggi :\", nilai_tertinggi)\n",
        "print(\"Nilai Terendah :\", nilai_terendah)\n",
        "print(\"Rata-rata Nilai :\", rata_rata)\n",
        "print(\"Jumlah Mahasiswa Lulus :\", lulus)\n",
        "print(\"Jumlah Mahasiswa Tidak Lulus :\", tidak_lulus)"
      ]
